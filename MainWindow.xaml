<Window x:Class="cyberg_guard_assistant_chat_app.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cyberg_guard_assistant_chat_app"
        mc:Ignorable="d"
        Title="MainWindow" Height="650" Width="1200">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <LinearGradientBrush.RelativeTransform>
                    <TransformGroup>
                        <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                        <SkewTransform CenterX="0.5" CenterY="0.5"/>
                        <RotateTransform Angle="267.709" CenterX="0.5" CenterY="0.5"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </LinearGradientBrush.RelativeTransform>
                <GradientStop Color="White" Offset="0.117"/>
                <GradientStop Color="#FF3EA9FB" Offset="1"/>
                <GradientStop Color="#FF40A9FA" Offset="0.667"/>
                <GradientStop Color="#FFE4F0F6" Offset="0.303"/>
                <GradientStop Color="#FF3FA9F9" Offset="0.53"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Image HorizontalAlignment="Left" Height="100" Margin="370,0,0,0" VerticalAlignment="Center" Width="100"/>
        <Image HorizontalAlignment="Left" Height="844" Margin="-120,99,0,0" VerticalAlignment="Top" Width="718" Source="/Copilot_20260429_104139.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="90.38"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image HorizontalAlignment="Left" Height="352" Margin="562,90,0,0" VerticalAlignment="Top" Width="380" Source="/Copilot_20260429_104951.png"/>
        <Border
            Width="220"
            Height="55"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="648,379,0,0">
            
            <Button x:Name="AnimatedButton"
                Content="CLICK ME"
                FontSize="16"
                FontWeight="Bold"
                Foreground="#FF3FA9FA"
                Background="#FFCBEEF9"
                Cursor="Hand"
                    
                BorderThickness="0" Click="OpenWelcomeChat_Click"
                    
        >
                <Button.Template>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <!-- Background with shadow -->
                            <Border CornerRadius="24"
                                Background="{TemplateBinding Background}">
                                <Border.Effect>
                                    <DropShadowEffect Color="RoyalBlue"
                                        BlurRadius="20"
                                        ShadowDepth="0"
                                        Opacity="0.6"/>
                                </Border.Effect>
                                <ContentPresenter HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </Border>

                            <!-- Particle layer -->
                            <Canvas>
                                <Ellipse x:Name="Circle1" Width="20" Height="20" Fill="White" Opacity="0.6"/>
                                <Ellipse x:Name="Circle2" Width="25" Height="25" Fill="LightBlue" Opacity="0.5"/>
                                <Ellipse x:Name="Circle3" Width="15" Height="15" Fill="White" Opacity="0.7"/>
                            </Canvas>
                        </Grid>

                        <!-- Animations -->
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <!-- Circle1 animation -->
                                            <DoubleAnimation Storyboard.TargetName="Circle1"
                                                Storyboard.TargetProperty="(Canvas.Left)"
                                                From="0" To="180" Duration="0:0:7"
                                                AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="Circle1"
                                                Storyboard.TargetProperty="(Canvas.Top)"
                                                From="0" To="40" Duration="0:0:7"
                                                AutoReverse="True"/>

                                            <!-- Circle2 animation -->
                                            <DoubleAnimation Storyboard.TargetName="Circle2"
                                                Storyboard.TargetProperty="(Canvas.Left)"
                                                From="40" To="160" Duration="0:0:7"
                                                AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="Circle2"
                                                Storyboard.TargetProperty="(Canvas.Top)"
                                                From="10" To="50" Duration="0:0:7"
                                                AutoReverse="True"/>

                                            <!-- Circle3 animation -->
                                            <DoubleAnimation Storyboard.TargetName="Circle3"
                                                Storyboard.TargetProperty="(Canvas.Left)"
                                                From="20" To="140" Duration="0:0:7"
                                                AutoReverse="True"/>
                                            <DoubleAnimation Storyboard.TargetName="Circle3"
                                                Storyboard.TargetProperty="(Canvas.Top)"
                                                From="5" To="45" Duration="0:0:7"
                                                AutoReverse="True"/>
                                            
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Border>

        <Label Content="cyber guard assistant chat" HorizontalAlignment="Left" Margin="612,317,0,0" VerticalAlignment="Top" RenderTransformOrigin="5.501,-0.769" Foreground="White" FontSize="24" FontFamily="Yu Gothic UI Semibold"/>
        <Image HorizontalAlignment="Left" Height="111" Margin="880,-3,0,0" VerticalAlignment="Top" Width="186" Source="/ChatGPT Image Apr 28, 2026, 01_48_54 PM.png" RenderTransformOrigin="0.66,0.28">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-0.289"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Image HorizontalAlignment="Left" Height="200" Margin="796,472,0,0" VerticalAlignment="Top" Width="300" Source="/Copilot_20260429_111533.png"/>
        <Label Content="staying protected is important" HorizontalAlignment="Left" Margin="812,325,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Foreground="White" FontSize="24" Width="678">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="90.067"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
        <Label Content="stay secure,and safe " HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="24" Foreground="White" RenderTransformOrigin="0.055,-4.448"/>

    </Grid>
</Window>
