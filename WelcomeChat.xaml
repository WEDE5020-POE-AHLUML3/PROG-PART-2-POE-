<Window x:Class="cyberg_guard_assistant_chat_app.WelcomeChat"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cyberg_guard_assistant_chat_app"
        mc:Ignorable="d"
        Title="WelcomeChat" Height="650" Width="1200">
    <Grid>
        <Image HorizontalAlignment="Left" Height="476" Margin="0,257,0,0" VerticalAlignment="Top" Width="566" Source="/Copilot_20260429_113841.png"/>
        <Image HorizontalAlignment="Left" Height="352" Margin="428,96,0,0" VerticalAlignment="Top" Width="380" Source="/Copilot_20260429_104951.png"/>
        <Image HorizontalAlignment="Left" Height="476" Margin="634,0,0,0" VerticalAlignment="Top" Width="566" Source="/Copilot_20260429_113841.png" RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="180.133"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
        <Border HorizontalAlignment="Left"
        VerticalAlignment="Top"
        Margin="408,380,0,0"
        Width="420" Height="46"
        CornerRadius="20"
        BorderBrush="#FF2596D7"
        BorderThickness="2"
        Background="White">
            <DockPanel LastChildFill="True">
                <!-- Send button inside textbox bubble -->
                <Button Content="➤"
                FontSize="16"
                Width="32"
                Background="#FF218BCB"
                Foreground="White"
                BorderThickness="0"
                Click="SendButton_Click"
                Margin="4"
                Cursor="Hand"
                ToolTip="Start Chat"
                DockPanel.Dock="Right"/>

                <!-- Text input -->
                <TextBox x:Name="NameInput"
                 TextWrapping="Wrap"
                 Width="398"
                 Height="46"
                 Padding="8"
                 BorderThickness="0"
                 Background="Transparent"/>
            </DockPanel>
        </Border>

        <Label Content="cyber guard assistant chat" HorizontalAlignment="Left" Margin="400,305,0,0" VerticalAlignment="Top" RenderTransformOrigin="5.501,-0.769" Foreground="Black" FontSize="36" FontFamily="Arial"/>
        <Label Content="what is your name ?" HorizontalAlignment="Left" Margin="408,346,0,0" VerticalAlignment="Top" FontSize="18"/>

    </Grid>
</Window>
